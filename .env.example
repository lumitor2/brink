# Copy to .env and fill in your Google OAuth "Desktop app" client.
# These are bundled into the build so users get one-click "Sign in with Google".
# .env is gitignored and never committed. Leave empty to fall back to entering
# the credentials in the app's Settings instead.
#
# See the README ("Google sign-in setup") for how to create the client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
